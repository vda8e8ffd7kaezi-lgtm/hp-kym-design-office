/* ===== リセット・ベース ===== */
*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

:root {
  --black: #111111;
  --white: #f8f8f6;
  --gray-light: #e8e8e6;
  --gray-mid: #9a9a98;
  --font-heading: 'Cormorant Garamond', serif;
  --font-body: 'Montserrat', sans-serif;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  background-color: var(--white);
  color: var(--black);
  font-family: var(--font-body);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ===== ナビゲーション ===== */
.nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 3rem;
  height: 56px;
  background-color: var(--white);
  border-bottom: 1px solid var(--gray-light);
}

.nav__logo {
  display: flex;
  align-items: center;
  text-decoration: none;
}

.nav__logo-img {
  height: 36px;
  width: auto;
  display: block;
}

.nav__links {
  list-style: none;
  display: flex;
  gap: 2.5rem;
}

.nav__links a {
  font-size: 0.65rem;
  font-weight: 400;
  letter-spacing: 0.2em;
  color: var(--black);
  text-decoration: none;
  transition: color 0.2s;
}

.nav__links a:hover {
  color: var(--gray-mid);
}

/* ===== ヒーローセクション ===== */
.hero {
  display: flex;
  min-height: 100vh;
  padding-top: 56px; /* nav の高さ分 */
}

/* 左カラム */
.hero__left {
  width: 38%;
  display: flex;
  align-items: flex-end;
  padding: 6rem 3rem 6rem 3rem;
  flex-shrink: 0;
}

.hero__headline {
  font-family: var(--font-heading);
  font-size: clamp(3rem, 5.5vw, 6rem);
  font-weight: 600;
  line-height: 1.05;
  letter-spacing: -0.01em;
  color: var(--black);
}

/* 右カラム */
.hero__right {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 画像エリア */
.hero__image-wrap {
  position: relative;
  flex: 1;
  overflow: hidden;
}

.hero__image {
  width: 100%;
  height: 100%;
}

.hero__image-placeholder {
  width: 100%;
  height: 100%;
  min-height: 380px;
  background: linear-gradient(
    160deg,
    #2a2a2a 0%,
    #4a4a4a 30%,
    #3a3a3a 60%,
    #1a1a1a 100%
  );
}


/* 縦書き会社名オーバーレイ */
.hero__brand-vertical {
  position: absolute;
  right: 1.5rem;
  top: 50%;
  transform: translateY(-50%) rotate(90deg);
  transform-origin: center center;
  font-family: var(--font-body);
  font-size: 0.65rem;
  font-weight: 500;
  letter-spacing: 0.35em;
  color: rgba(255, 255, 255, 0.75);
  white-space: nowrap;
  writing-mode: vertical-rl;
  text-orientation: mixed;
  /* CSS writing-mode を使う場合は rotate 不要 */
  transform: none;
  right: 0.75rem;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  writing-mode: vertical-rl;
  text-orientation: mixed;
  letter-spacing: 0.3em;
}

/* 画像下テキストエリア */
.hero__description {
  padding: 2.5rem 3rem 4rem 0;
  max-width: 480px;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.hero__body {
  font-size: 0.75rem;
  font-weight: 300;
  line-height: 2;
  color: #444;
  letter-spacing: 0.05em;
}

/* Explore CTA */
.hero__cta {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--black);
  text-decoration: none;
  font-size: 0.7rem;
  font-weight: 400;
  letter-spacing: 0.15em;
  transition: gap 0.25s ease;
}

.hero__cta:hover {
  gap: 1.25rem;
}

.hero__cta-arrow {
  width: 40px;
  height: 12px;
  flex-shrink: 0;
}

/* ===== レスポンシブ（タブレット・スマホ） ===== */
@media (max-width: 900px) {
  .hero {
    flex-direction: column;
    min-height: auto;
  }

  .hero__left {
    width: 100%;
    padding: 3rem 2rem 2rem;
    align-items: flex-start;
  }

  .hero__headline {
    font-size: clamp(2.5rem, 10vw, 4rem);
  }

  .hero__right {
    width: 100%;
  }

  .hero__image-placeholder {
    min-height: 260px;
  }

  .hero__description {
    padding: 2rem 2rem 3rem;
    max-width: 100%;
  }
}

@media (max-width: 600px) {
  .nav {
    padding: 0 1.5rem;
  }

  .nav__links {
    gap: 1.5rem;
  }

  .hero__left {
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .hero__description {
    padding: 1.5rem 1.5rem 2.5rem;
  }
}
